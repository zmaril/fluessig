{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fluessig.dev/schemas/api.v0.json",
  "title": "fluessig api.json (format 0)",
  "description": "The op layer lowered from a .tsp: interfaces, op shapes, params, returns, and the DTO models the ops reference. The input to `fluessig bindgen`.",
  "type": "object",
  "required": ["fluessig", "models", "interfaces"],
  "additionalProperties": false,
  "properties": {
    "fluessig": {
      "type": "object",
      "required": ["format"],
      "properties": {
        "format": { "const": 0 },
        "emitter": { "type": "string" },
        "compiler": { "type": "string" }
      }
    },
    "source": { "type": "string" },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "fields"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "doc": { "type": ["string", "null"] },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type", "nullable"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "type": { "$ref": "#/$defs/apiType" },
                "nullable": { "type": "boolean" }
              }
            }
          }
        }
      }
    },
    "interfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "ops"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "doc": { "type": ["string", "null"] },
          "ops": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "shape", "params", "returns"],
              "additionalProperties": false,
              "properties": {
                "name": { "type": "string" },
                "doc": { "type": ["string", "null"] },
                "shape": { "enum": ["ctor", "unary", "stream", "manual"] },
                "params": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "type"],
                    "additionalProperties": false,
                    "properties": {
                      "name": { "type": "string" },
                      "type": { "$ref": "#/$defs/apiType" },
                      "optional": { "const": true }
                    }
                  }
                },
                "returns": { "$ref": "#/$defs/apiType" }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "apiType": {
      "oneOf": [
        { "type": "string", "description": "a scalar name, or \"void\"" },
        {
          "type": "object",
          "required": ["model"],
          "additionalProperties": false,
          "properties": { "model": { "type": "string" } }
        },
        {
          "type": "object",
          "required": ["enum"],
          "additionalProperties": false,
          "properties": { "enum": { "type": "string" } }
        },
        {
          "type": "object",
          "required": ["list"],
          "additionalProperties": false,
          "properties": { "list": { "$ref": "#/$defs/apiType" } }
        },
        {
          "type": "object",
          "required": ["nullable"],
          "additionalProperties": false,
          "properties": { "nullable": { "$ref": "#/$defs/apiType" } }
        }
      ]
    }
  }
}
