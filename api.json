    {
      "name": "Entl",
      "doc": "An open entl database. Heavy ops are unary (off-thread in async hosts).",
      "ops": [
        {
          "name": "open",
          "doc": "Open (or create) the .duckdb at `dbPath` and apply the schema.",
          "shape": "ctor",
          "params": [
            {
              "name": "dbPath",
              "type": "string"
            }
          ],
          "returns": "void"
        },
        {
          "name": "loadGit",
          "doc": "Load git history from `repoPath` (one-way, incremental).",
          "shape": "unary",
          "params": [
            {
              "name": "repoPath",
              "type": "string"
            }
          ],
          "returns": {
            "model": "GitStats"
          }
        },
        {
          "name": "loadGithub",
          "doc": "Load GitHub data (events/PRs/issues/Actions). Needs a token.",
          "shape": "unary",
          "params": [
            {
              "name": "repoPath",
              "type": "string"
            }
          ],
          "returns": {
            "model": "GithubStats"
          }
        },
        {
          "name": "query",
          "doc": "Run a SQL query; JSON rows back.",
          "shape": "unary",
          "params": [
            {
              "name": "sql",
              "type": "string"
            }
          ],
          "returns": "string"
        },
        {
          "name": "queryArrow",
          "doc": "Run a SQL query; the result as one Arrow IPC stream (schema + all batches) —\nthe dataframe on-ramp (pyarrow → pandas/polars, apache-arrow JS, red-arrow).",
          "shape": "unary",
          "params": [
            {
              "name": "sql",
              "type": "string"
            }
          ],
          "returns": "bytes"
        },
        {
          "name": "sink",
          "doc": "Pull `repoPath` and sync it into a target store, in one call.",
          "shape": "unary",
          "params": [
            {
              "name": "repoPath",
              "type": "string"
            },
            {
              "name": "options",
              "type": {
                "model": "SinkOptions"
              }
            }
          ],
          "returns": {
            "model": "SinkStats"
          }
        },
        {
          "name": "extract",
          "doc": "Read a store back into canonical rows (JSON; oids hex, timestamps RFC3339).",
          "shape": "unary",
          "params": [
            {
              "name": "options",
              "type": {
                "model": "ExtractOptions"
              }
            }
          ],
          "returns": "string"
        },
        {
          "name": "changes",
          "doc": "Stream the change batches from one pull (the stream plane).",
          "shape": "stream",
          "params": [
            {
              "name": "repoPath",
              "type": "string"
            },
            {
              "name": "options",
              "type": {
                "model": "ChangesOptions"
              },
              "optional": true
            }
          ],
          "returns": {
            "model": "ChangeBatch"
          }
        },
        {
          "name": "driverPlan",
          "doc": "Backfill this store into a driver target: stream {sql, params} for the host to execute.",
          "shape": "stream",
          "params": [
            {
              "name": "options",
              "type": {
                "model": "DriverPlanOptions"
              },
              "optional": true
            }
          ],
          "returns": {
            "model": "Statement"
          }
        },
        {
          "name": "rebuild",
          "doc": "Reconstruct a git repo from a store (needs objects: true at sink time). Returns commits rebuilt.",
          "shape": "unary",
          "params": [
            {
              "name": "options",
              "type": {
                "model": "RebuildOptions"
              }
            }
          ],
          "returns": "int64"
        },
        {
          "name": "watch",
          "doc": "Poll-loop sync with a host callback (ThreadsafeFunction / GVL re-entry) — hand-written per binding.",
          "shape": "manual",
          "params": [
            {
              "name": "repoPath",
              "type": "string"
            },
            {
              "name": "intervalSecs",
              "type": "int32"
            }
          ],
          "returns": "void"
        }
      ]
    }
